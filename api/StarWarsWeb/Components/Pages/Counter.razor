@page "/counter"
@inject HttpClient Http
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;
    private string? apiResult;

    private async Task IncrementCount()
    {
        currentCount++;
        await CallExternalApi();
    }

    private async Task CallExternalApi()
    {
        try
        {
            // Remplacez par votre URL d'API réelle
            var response = await Http.GetFromJsonAsync<dynamic>("https://api.example.com/data");
            apiResult = response?.ToString() ?? "Pas de résultat";
        }
        catch (Exception ex)
        {
            apiResult = $"Erreur : {ex.Message}";
        }
    }
}
